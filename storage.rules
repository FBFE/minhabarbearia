rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Fotos de clientes: permite upload público (página de agendamento sem login)
    // Restrições: apenas imagens, até 5MB
    match /barbershops/{slug}/clients/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                  && request.resource.contentType.matches('image/.*');
    }

    // Logo da barbearia: só o dono (auth) pode enviar; leitura pública para a página
    match /logos/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                  && request.auth.uid == userId
                  && request.resource.size < 5 * 1024 * 1024
                  && request.resource.contentType.matches('image/.*');
    }

    // Fundo da página da barbearia: só o dono (auth) pode enviar; leitura pública
    match /backgrounds/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                  && request.auth.uid == userId
                  && request.resource.size < 5 * 1024 * 1024
                  && request.resource.contentType.matches('image/.*');
    }

    // Imagens dos serviços (foto do corte): leitura/listagem públicas (agendamento + SDK listAll);
    // só utilizadores autenticados criam/atualizam ficheiros (upload com image/* e ≤ 5MB).
    // Usamos create/update em vez de write para não depender de request.resource em deletes.
    match /services/{slug}/{allPaths=**} {
      allow read: if true;
      allow create, update: if request.auth != null
          && request.resource.size < 5 * 1024 * 1024
          && request.resource.contentType.matches('image/.*');
    }
  }
}
